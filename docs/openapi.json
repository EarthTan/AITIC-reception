  "components": {
    "schemas": {
      "AdapterHealthStatus": {
        "type": "string",
        "enum": [
          "online",
          "offline",
          "error"
        ],
        "title": "AdapterHealthStatus"
      },
      "AdapterStatusOut": {
        "properties": {
          "adapter_name": {
            "type": "string",
            "title": "Adapter Name"
          },
          "status": {
            "$ref": "#/components/schemas/AdapterHealthStatus"
          },
          "last_heartbeat": {
            "type": "string",
            "format": "date-time",
            "title": "Last Heartbeat"
          },
          "detail": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Detail"
          }
        },
        "type": "object",
        "required": [
          "adapter_name",
          "status",
          "last_heartbeat",
          "detail"
        ],
        "title": "AdapterStatusOut"
      },
      "Body_preview_import_api_import_preview_post": {
        "properties": {
          "file": {
            "type": "string",
            "contentMediaType": "application/octet-stream",
            "title": "File"
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_preview_import_api_import_preview_post"
      },
      "CardWriteLogOut": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "visit_id": {
            "type": "integer",
            "title": "Visit Id"
          },
          "card_uid": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Card Uid"
          },
          "write_status": {
            "$ref": "#/components/schemas/WriteStatus"
          },
          "error_message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Message"
          },
          "written_at": {
            "type": "string",
            "format": "date-time",
            "title": "Written At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "visit_id",
          "card_uid",
          "write_status",
          "error_message",
          "written_at"
        ],
        "title": "CardWriteLogOut"
      },
      "CardWriteRequest": {
        "properties": {
          "visit_ids": {
            "items": {
              "type": "integer"
            },
            "type": "array",
            "title": "Visit Ids"
          }
        },
        "type": "object",
        "required": [
          "visit_ids"
        ],
        "title": "CardWriteRequest"
      },
      "CardWriteResult": {
        "properties": {
          "visit_id": {
            "type": "integer",
            "title": "Visit Id"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "error_message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Message"
          }
        },
        "type": "object",
        "required": [
          "visit_id",
          "status"
        ],
        "title": "CardWriteResult"
      },
      "EntrySource": {
        "type": "string",
        "enum": [
          "auto",
          "manual"
        ],
        "title": "EntrySource"
      },
      "FailReason": {
        "type": "string",
        "enum": [
          "name_mismatch",
          "date_mismatch",
          "card_not_found"
        ],
        "title": "FailReason"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "IdentityType": {
        "type": "string",
        "enum": [
          "企业领导",
          "企业员工",
          "学校老师",
          "大学生",
          "中小学生",
          "政府官员"
        ],
        "title": "IdentityType"
      },
      "ImportCommitRequest": {
        "properties": {
          "preview_id": {
            "type": "string",
